From 0000000000000000000000000000000000000000 Mon Sep 17 00:00:00 2001
From: Entrpi <entrpi@proton.me>
Date: Fri, 13 Feb 2026 16:42:14 +1100
Subject: [PATCH] drm/panthor: enable ACE-Lite bus coherency on Sky1

The previous commit forced all GPU memory attributes to non-cacheable
on Sky1 to fix display corruption caused by the non-snooping DPU
reading stale DRAM. This was correct but conservative -- it disabled
GPU L2 caching entirely, increasing DRAM bandwidth pressure.

The vendor kbase driver avoids this by enabling ACE-Lite bus coherency
(writing 0 to GPU register 0x304 instead of 31/NONE). With ACE-Lite,
the GPU participates in the CHI fabric as an RN-I node: GPU L2
evictions route through the Home Node (HN-F) and are absorbed into the
System Level Cache (SLC). The DPU's reads also route through HN-F via
its SMMU, so the SLC acts as a convergence point -- GPU write-back
data is visible to DPU reads without requiring NC memory attributes.

Changes:
- panthor_regs.h: Add GPU_COHERENCY_SHAREABLE_CACHE (bit 5) define
- panthor_device.h: Add ace_lite flag for partial bus coherency
- panthor_device.c: Set ace_lite=true for Sky1 after forcing
  coherent=false; skip NC memattr info message when ACE-Lite active
- panthor_gpu.c: Rewrite panthor_gpu_coherency_set() to write
  ACE_LITE (0) instead of NONE (31) when ace_lite is set, and enable
  Shareable Cache Support (bit 5) when hardware reports support.
  Also fixes an upstream bug where the coherent path wrote BIT(0)=1
  (ACE) instead of 0 (ACE_LITE) due to misuse of PROT_BIT macro.
- panthor_mmu.c: Skip NC memattr override when ace_lite is active,
  allowing GPU to use write-back caching with SLC visibility
---
 drivers/gpu/drm/panthor/panthor_device.c | 30 ++++++++++++++++--------
 drivers/gpu/drm/panthor/panthor_device.h | 14 +++++++++++
 drivers/gpu/drm/panthor/panthor_gpu.c    | 23 ++++++++++++++++--
 drivers/gpu/drm/panthor/panthor_mmu.c    | 20 +++++++++-------
 drivers/gpu/drm/panthor/panthor_regs.h   |  1 +
 5 files changed, 67 insertions(+), 21 deletions(-)

diff --git a/drivers/gpu/drm/panthor/panthor_device.c b/drivers/gpu/drm/panthor/panthor_device.c
index be6739113009b..aabd2630e8354 100644
--- a/drivers/gpu/drm/panthor/panthor_device.c
+++ b/drivers/gpu/drm/panthor/panthor_device.c
@@ -146,15 +146,12 @@ static int panthor_gpu_coherency_init(struct panthor_device *ptdev)
 	ptdev->coherent = device_get_dma_attr(ptdev->base.dev) == DEV_DMA_COHERENT;
 
 	/*
-	 * Sky1 SoC: The DSDT sets _CCA=1 for the GPU, but the SoC was
-	 * designed for non-coherent GPU operation (DT has system-coherency=0
-	 * and no dma-coherent).  The GPU shares framebuffer memory with the
-	 * DPU which is non-coherent (_CCA=0).  If the GPU enables ACE-Lite
-	 * coherency while the DPU reads non-coherently, the DPU sees stale
-	 * DRAM content causing visible rendering artefacts.
-	 *
-	 * Force the GPU coherency protocol to NONE while leaving the kernel
-	 * DMA layer coherent (the interconnect path IS cache-coherent).
+	 * Sky1 SoC: The DSDT sets _CCA=1 for the GPU, but the platform
+	 * uses ACE-Lite (DT has system-coherency=0).  The GPU hardware
+	 * supports full ACE, but ACE-Lite is the correct choice since
+	 * the DPU is non-snooping and reads from SLC/DRAM.
+	 * Force coherent=false to avoid full ACE protocol selection,
+	 * then enable ACE-Lite below for SLC participation.
 	 */
 	if (ptdev->coherent && (panthor_force_noncoherent || panthor_is_sky1(ptdev))) {
 		drm_info(&ptdev->base,
@@ -164,6 +161,19 @@ static int panthor_gpu_coherency_init(struct panthor_device *ptdev)
 		ptdev->coherent = false;
 	}
 
+	/*
+	 * Sky1: Enable ACE-Lite bus coherency.  The GPU is not behind a
+	 * system IOMMU on this SoC, but it supports ACE-Lite on the CHI
+	 * fabric.  With ACE-Lite, GPU L2 evictions route through HN-F
+	 * and are absorbed into the SLC (System Level Cache), making WB
+	 * data visible to the non-snooping DPU without forcing NC memattr.
+	 * This matches the vendor kbase driver's configuration.
+	 */
+	if (!ptdev->coherent && panthor_is_sky1(ptdev)) {
+		ptdev->ace_lite = true;
+		drm_info(&ptdev->base, "Enabling ACE-Lite bus coherency\n");
+	}
+
 	if (!ptdev->coherent)
 		return 0;
 
@@ -605,7 +615,7 @@ int panthor_device_init(struct panthor_device *ptdev)
 		goto err_unplug_gpu;
 
 	ptdev->has_iommu = device_iommu_mapped(ptdev->base.dev);
-	if (!ptdev->has_iommu && !ptdev->coherent)
+	if (!ptdev->has_iommu && !ptdev->coherent && !ptdev->ace_lite)
 		drm_info(&ptdev->base,
 			 "GPU not behind system IOMMU; forcing non-cacheable memory attributes\n");
 
diff --git a/drivers/gpu/drm/panthor/panthor_device.h b/drivers/gpu/drm/panthor/panthor_device.h
index 72ede52e66172..869ef63e4b1bd 100644
--- a/drivers/gpu/drm/panthor/panthor_device.h
+++ b/drivers/gpu/drm/panthor/panthor_device.h
@@ -146,6 +146,20 @@ struct panthor_device {
 	/** @coherent: True if the CPU/GPU are memory coherent. */
 	bool coherent;
 
+	/**
+	 * @ace_lite: True if GPU uses ACE-Lite bus coherency.
+	 *
+	 * ACE-Lite is a partial coherency mode where the GPU participates in
+	 * the CHI fabric as an RN-I (Request Node - I/O). GPU L2 evictions
+	 * route through HN-F (Home Node) and may be absorbed into the SLC
+	 * (System Level Cache), making write-back data visible to other
+	 * fabric-connected masters like the DPU without requiring NC memattr.
+	 *
+	 * This is distinct from @coherent (full ACE snooping) and from no
+	 * coherency (COHERENCY_NONE, GPU completely outside the fabric).
+	 */
+	bool ace_lite;
+
 	/** @has_iommu: True if the GPU is behind a system IOMMU/SMMU. */
 	bool has_iommu;
 
diff --git a/drivers/gpu/drm/panthor/panthor_gpu.c b/drivers/gpu/drm/panthor/panthor_gpu.c
index e711a0a8da9ec..d015f9e4370dc 100644
--- a/drivers/gpu/drm/panthor/panthor_gpu.c
+++ b/drivers/gpu/drm/panthor/panthor_gpu.c
@@ -51,8 +51,27 @@ struct panthor_gpu {
 
 static void panthor_gpu_coherency_set(struct panthor_device *ptdev)
 {
-	gpu_write(ptdev, GPU_COHERENCY_PROTOCOL,
-		ptdev->coherent ? GPU_COHERENCY_PROT_BIT(ACE_LITE) : GPU_COHERENCY_NONE);
+	u32 val;
+
+	if (ptdev->coherent || ptdev->ace_lite)
+		val = GPU_COHERENCY_ACE_LITE;
+	else
+		val = GPU_COHERENCY_NONE;
+
+	/*
+	 * Enable Shareable Cache Support when using a coherency protocol.
+	 * This allows the GPU to participate in shared cache allocation
+	 * on the CHI fabric (SLC), matching vendor driver behaviour.
+	 */
+	if (val != GPU_COHERENCY_NONE) {
+		u32 features = gpu_read(ptdev, GPU_COHERENCY_FEATURES);
+
+		if (features & GPU_COHERENCY_PROT_BIT(ACE_LITE) &&
+		    features & GPU_COHERENCY_SHAREABLE_CACHE)
+			val |= GPU_COHERENCY_SHAREABLE_CACHE;
+	}
+
+	gpu_write(ptdev, GPU_COHERENCY_PROTOCOL, val);
 }
 
 static void panthor_gpu_l2_config_set(struct panthor_device *ptdev)
diff --git a/drivers/gpu/drm/panthor/panthor_mmu.c b/drivers/gpu/drm/panthor/panthor_mmu.c
index 05b09b9aa4957..a5154a4cb05dc 100644
--- a/drivers/gpu/drm/panthor/panthor_mmu.c
+++ b/drivers/gpu/drm/panthor/panthor_mmu.c
@@ -1943,7 +1943,8 @@ void panthor_vm_heaps_sizes(struct panthor_file *pfile, struct drm_memory_stats
 	xa_unlock(&pfile->vms->xa);
 }
 
-static u64 mair_to_memattr(u64 mair, bool coherent, bool has_iommu)
+static u64 mair_to_memattr(u64 mair, bool coherent, bool has_iommu,
+			   bool ace_lite)
 {
 	u64 memattr = 0;
 	u32 i;
@@ -1961,15 +1962,15 @@ static u64 mair_to_memattr(u64 mair, bool coherent, bool has_iommu)
 			out_attr = AS_MEMATTR_AARCH64_INNER_OUTER_NC |
 				   AS_MEMATTR_AARCH64_SH_MIDGARD_INNER |
 				   AS_MEMATTR_AARCH64_INNER_ALLOC_EXPL(false, false);
-		} else if (!has_iommu && !coherent) {
-			/* GPU is non-coherent and not behind a system IOMMU.
-			 * On SoCs where the GPU and display engine share
-			 * framebuffers, GPU write-back data may be absorbed
-			 * by a system-level cache while the non-coherent
-			 * display engine reads stale DRAM, causing visible
-			 * rendering corruption.
+		} else if (!has_iommu && !coherent && !ace_lite) {
+			/* GPU is non-coherent, not behind a system IOMMU,
+			 * and not using ACE-Lite bus coherency.  GPU WB
+			 * data may remain in a system-level cache invisible
+			 * to non-snooping masters.
 			 *
 			 * Force non-cacheable to guarantee DRAM visibility.
+			 * When ACE-Lite is active, WB data routes through
+			 * HN-F/SLC and is visible to fabric-connected readers.
 			 */
 			out_attr = AS_MEMATTR_AARCH64_INNER_OUTER_NC |
 				   AS_MEMATTR_AARCH64_SH_MIDGARD_INNER |
@@ -2362,7 +2363,8 @@ panthor_vm_create(struct panthor_device *ptdev, bool for_mcu,
 		goto err_sched_fini;
 
 	mair = io_pgtable_ops_to_pgtable(vm->pgtbl_ops)->cfg.arm_lpae_s1_cfg.mair;
-	vm->memattr = mair_to_memattr(mair, ptdev->coherent, ptdev->has_iommu);
+	vm->memattr = mair_to_memattr(mair, ptdev->coherent, ptdev->has_iommu,
+				     ptdev->ace_lite);
 
 	mutex_lock(&ptdev->mmu->vm.lock);
 	list_add_tail(&vm->node, &ptdev->mmu->vm.list);
diff --git a/drivers/gpu/drm/panthor/panthor_regs.h b/drivers/gpu/drm/panthor/panthor_regs.h
index 14296e2f94a98..77add31facd68 100644
--- a/drivers/gpu/drm/panthor/panthor_regs.h
+++ b/drivers/gpu/drm/panthor/panthor_regs.h
@@ -122,6 +122,7 @@
 #define   GPU_COHERENCY_ACE_LITE			0
 #define   GPU_COHERENCY_ACE				1
 #define   GPU_COHERENCY_NONE				31
+#define   GPU_COHERENCY_SHAREABLE_CACHE			BIT(5)
 
 #define MCU_CONTROL					0x700
 #define MCU_CONTROL_ENABLE				1
