From 0000000000000000000000000000000000000000 Mon Sep 17 00:00:00 2001
From: Entrpi <entrpi@proton.me>
Date: Fri, 13 Feb 2026 16:39:04 +1100
Subject: [PATCH] drm/panthor: force non-coherent GPU mode and NC memattr on
 Sky1

The Sky1 SoC GPU is not behind a system IOMMU (no iommus DT property,
no IORT Named Component entry). When the GPU uses write-back memory
attributes, data is absorbed by the system-level cache and the
non-snooping DPU reads stale DRAM, causing visible display corruption.

Add a Sky1 platform quirk that forces the GPU coherency protocol to
NONE even when firmware reports coherent (_CCA=1). Detect the absence
of a system IOMMU via device_iommu_mapped() and force all cacheable
MAIR entries to non-cacheable in mair_to_memattr() when the GPU is
both non-coherent and not behind an IOMMU.

This is a conservative fix that trades GPU L2 cache utilization for
guaranteed DRAM visibility. A follow-up change will enable ACE-Lite
bus coherency to restore GPU cache performance while maintaining
display correctness.
---
 drivers/gpu/drm/panthor/panthor_device.c | 31 ++++++++++++++++++++++++
 drivers/gpu/drm/panthor/panthor_device.h |  3 +++
 drivers/gpu/drm/panthor/panthor_mmu.c    | 17 +++++++++++--
 3 files changed, 49 insertions(+), 2 deletions(-)

diff --git a/drivers/gpu/drm/panthor/panthor_device.c b/drivers/gpu/drm/panthor/panthor_device.c
index 1c99e8420c9f0..be6739113009b 100644
--- a/drivers/gpu/drm/panthor/panthor_device.c
+++ b/drivers/gpu/drm/panthor/panthor_device.c
@@ -5,7 +5,9 @@
 
 #include <linux/clk.h>
 #include <linux/delay.h>
+#include <linux/iommu.h>
 #include <linux/mm.h>
+#include <linux/moduleparam.h>
 #include <linux/of.h>
 #include <linux/platform_device.h>
 #include <linux/pm_domain.h>
@@ -134,10 +136,34 @@ static int sky1_smc_scmi_power_set(struct device *dev, u32 domain, u32 state)
 	return 0;
 }
 
+static bool panthor_force_noncoherent;
+module_param_named(force_noncoherent, panthor_force_noncoherent, bool, 0444);
+MODULE_PARM_DESC(force_noncoherent,
+	"Force GPU to non-coherent mode even when firmware reports coherent");
+
 static int panthor_gpu_coherency_init(struct panthor_device *ptdev)
 {
 	ptdev->coherent = device_get_dma_attr(ptdev->base.dev) == DEV_DMA_COHERENT;
 
+	/*
+	 * Sky1 SoC: The DSDT sets _CCA=1 for the GPU, but the SoC was
+	 * designed for non-coherent GPU operation (DT has system-coherency=0
+	 * and no dma-coherent).  The GPU shares framebuffer memory with the
+	 * DPU which is non-coherent (_CCA=0).  If the GPU enables ACE-Lite
+	 * coherency while the DPU reads non-coherently, the DPU sees stale
+	 * DRAM content causing visible rendering artefacts.
+	 *
+	 * Force the GPU coherency protocol to NONE while leaving the kernel
+	 * DMA layer coherent (the interconnect path IS cache-coherent).
+	 */
+	if (ptdev->coherent && (panthor_force_noncoherent || panthor_is_sky1(ptdev))) {
+		drm_info(&ptdev->base,
+			 "Forcing non-coherent mode (%s)\n",
+			 panthor_force_noncoherent ? "module parameter" :
+						    "Sky1 platform quirk");
+		ptdev->coherent = false;
+	}
+
 	if (!ptdev->coherent)
 		return 0;
 
@@ -578,6 +604,11 @@ int panthor_device_init(struct panthor_device *ptdev)
 	if (ret)
 		goto err_unplug_gpu;
 
+	ptdev->has_iommu = device_iommu_mapped(ptdev->base.dev);
+	if (!ptdev->has_iommu && !ptdev->coherent)
+		drm_info(&ptdev->base,
+			 "GPU not behind system IOMMU; forcing non-cacheable memory attributes\n");
+
 	ret = panthor_mmu_init(ptdev);
 	if (ret)
 		goto err_unplug_gpu;
diff --git a/drivers/gpu/drm/panthor/panthor_device.h b/drivers/gpu/drm/panthor/panthor_device.h
index 75817ca820a81..72ede52e66172 100644
--- a/drivers/gpu/drm/panthor/panthor_device.h
+++ b/drivers/gpu/drm/panthor/panthor_device.h
@@ -146,6 +146,9 @@ struct panthor_device {
 	/** @coherent: True if the CPU/GPU are memory coherent. */
 	bool coherent;
 
+	/** @has_iommu: True if the GPU is behind a system IOMMU/SMMU. */
+	bool has_iommu;
+
 	/** @gpu_info: GPU information. */
 	struct drm_panthor_gpu_info gpu_info;
 
diff --git a/drivers/gpu/drm/panthor/panthor_mmu.c b/drivers/gpu/drm/panthor/panthor_mmu.c
index 7761c45bc75e5..05b09b9aa4957 100644
--- a/drivers/gpu/drm/panthor/panthor_mmu.c
+++ b/drivers/gpu/drm/panthor/panthor_mmu.c
@@ -1943,7 +1943,7 @@ void panthor_vm_heaps_sizes(struct panthor_file *pfile, struct drm_memory_stats
 	xa_unlock(&pfile->vms->xa);
 }
 
-static u64 mair_to_memattr(u64 mair, bool coherent)
+static u64 mair_to_memattr(u64 mair, bool coherent, bool has_iommu)
 {
 	u64 memattr = 0;
 	u32 i;
@@ -1961,6 +1961,19 @@ static u64 mair_to_memattr(u64 mair, bool coherent)
 			out_attr = AS_MEMATTR_AARCH64_INNER_OUTER_NC |
 				   AS_MEMATTR_AARCH64_SH_MIDGARD_INNER |
 				   AS_MEMATTR_AARCH64_INNER_ALLOC_EXPL(false, false);
+		} else if (!has_iommu && !coherent) {
+			/* GPU is non-coherent and not behind a system IOMMU.
+			 * On SoCs where the GPU and display engine share
+			 * framebuffers, GPU write-back data may be absorbed
+			 * by a system-level cache while the non-coherent
+			 * display engine reads stale DRAM, causing visible
+			 * rendering corruption.
+			 *
+			 * Force non-cacheable to guarantee DRAM visibility.
+			 */
+			out_attr = AS_MEMATTR_AARCH64_INNER_OUTER_NC |
+				   AS_MEMATTR_AARCH64_SH_MIDGARD_INNER |
+				   AS_MEMATTR_AARCH64_INNER_ALLOC_EXPL(false, false);
 		} else {
 			out_attr = AS_MEMATTR_AARCH64_INNER_OUTER_WB |
 				   AS_MEMATTR_AARCH64_INNER_ALLOC_EXPL(inner & 1, inner & 2);
@@ -2349,7 +2362,7 @@ panthor_vm_create(struct panthor_device *ptdev, bool for_mcu,
 		goto err_sched_fini;
 
 	mair = io_pgtable_ops_to_pgtable(vm->pgtbl_ops)->cfg.arm_lpae_s1_cfg.mair;
-	vm->memattr = mair_to_memattr(mair, ptdev->coherent);
+	vm->memattr = mair_to_memattr(mair, ptdev->coherent, ptdev->has_iommu);
 
 	mutex_lock(&ptdev->mmu->vm.lock);
 	list_add_tail(&vm->node, &ptdev->mmu->vm.list);
