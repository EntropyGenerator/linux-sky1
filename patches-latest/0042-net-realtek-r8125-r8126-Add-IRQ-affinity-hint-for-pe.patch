+                for_each_online_cpu(cpu) {
+                        if (!rtl8126_is_little_core(cpu))
+                                cpumask_set_cpu(cpu, big_core_mask);
+                }
+        }
+#endif
 
 #if defined(RTL_USE_NEW_INTR_API)
         for (i=0; i<tp->irq_nvecs; i++) {
@@ -14025,6 +14054,9 @@ static int rtl8126_alloc_irq(struct rtl8126_private *tp)
 
                 irq->vector = pci_irq_vector(tp->pci_dev, i);
                 irq->requested = 1;
+#ifdef CONFIG_ARM64
+                irq_set_affinity_hint(irq->vector, big_core_mask);
+#endif
         }
 #else
         unsigned long irq_flags = 0;
@@ -14062,6 +14094,9 @@ static int rtl8126_alloc_irq(struct rtl8126_private *tp)
         if (rc)
                 rtl8126_free_irq(tp);
 
+#ifdef CONFIG_ARM64
+        free_cpumask_var(big_core_mask);
+#endif
         return rc;
 }
 
